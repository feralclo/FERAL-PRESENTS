{
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/abandoned-carts/",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/stripe-health/",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/announcement-emails/",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/payment-digest/",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/exchange-rates/",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/guest-list-reminders/",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/ep-payouts/",
      "schedule": "0 3 1 * *"
    },
    {
      "path": "/api/cron/rep-rank-snapshots/",
      "schedule": "0 2 * * 1"
    },
    {
      "path": "/api/cron/rep-streak-reset/",
      "schedule": "5 0 * * *"
    },
    {
      "path": "/api/cron/stories-expire/",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/domain-verify-poll/",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/event-reminders/",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/streak-at-risk/",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/spotify-trending-refresh/",
      "schedule": "0 */6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/event/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "public, max-age=60, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/contract/:path*",
      "has": [{ "type": "host", "value": "www.agencyferal.com" }],
      "destination": "/static/contract/:path*"
    },
    {
      "source": "/contract/:path*",
      "has": [{ "type": "host", "value": "agencyferal.com" }],
      "destination": "/static/contract/:path*"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.agencyferal.com" }],
      "destination": "/static/agencyferal/index.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "agencyferal.com" }],
      "destination": "/static/agencyferal/index.html"
    },
    {
      "source": "/artist",
      "destination": "/static/artist/index.html"
    },
    {
      "source": "/artist-invite",
      "destination": "/static/artist-invite/index.html"
    },
    {
      "source": "/artist-login",
      "destination": "/static/artist-login/index.html"
    }
  ]
}
